# Application Settings
APP_NAME="AudioMatch"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Find Your Perfect Audio Setup"
DEBUG=True
PORT=8000
LOG_LEVEL=INFO

# Database Configuration (PostgreSQL with pgvector)
DATABASE_URL=postgresql://neondb_owner:npg_d2JgsptluB0i@ep-empty-cherry-a1y73x62-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_TIMEOUT=30

# VoyageAI API Configuration
VOYAGE_API_KEY=pa-gvkagr8m53wW4NJVlC62gtsk7rIXZSbbdCXlq_HHVNS
VOYAGE_MODEL=voyage-3.5-lite
VOYAGE_INPUT_TYPE=document
EMBEDDING_DIMENSIONS=1024

# CRITICAL: Rate limiting settings for free tier (3 RPM)
EMBEDDING_BATCH_SIZE=100  # Max texts per API call (VoyageAI limit)
VOYAGE_RATE_LIMIT_RPM=3  # Free tier limit
VOYAGE_RATE_LIMIT_DELAY=21  # Same as interval

# LLM Configuration (Using Poe API)
POE_API_KEY=_Lp_WAx0FzgAOOakrn0_uPlhoej5hGC7VFQEalGHZ1Q
LLM_MODEL=Assistant
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=30

# Upstash Redis Configuration
UPSTASH_REDIS_REST_URL="https://romantic-mackerel-30092.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXWMAAIncDI2NGMyOGYyMjk3N2E0N2RjYTViNWM0ZDFmYjI4ZGI0Y3AyMzAwOTI"

# Redis Cache Configuration (in seconds)
REDIS_CACHE_TTL=3600          # 1 hour - for retrieval results and general cache
REDIS_SESSION_TTL=86400       # 24 hours - for session data

# API Documentation (set to false in production to disable /docs and /redoc)
ENABLE_DOCS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOGGING_ENABLED=true
LOG_LEVEL=INFO
LOG_TO_FILE=false

# CORS
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]
